# ========================================
# 朋友聊天室 — 环境变量配置模板
# 使用方法：复制为 .env 后修改
#   cp .env.example .env
# ========================================

# ===== 服务器配置 =====
NODE_ENV=development
PORT=3000

# ===== JWT 密钥（务必生成你自己的随机字符串！） =====
# Linux/Mac: openssl rand -hex 64
# Windows:   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=请生成你自己的64字节随机字符串
JWT_REFRESH_SECRET=请生成你自己的64字节随机字符串
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== 管理员密码（管理后台 /admin 的登录密码） =====
ADMIN_PASSWORD=请修改为你自己的管理员密码

# ===== CORS 白名单（允许多个来源用逗号分隔） =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ===== 限流配置 =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# ===== 日志级别 (debug | info | warn | error) =====
LOG_LEVEL=debug

# ===== ngrok 公网隧道（可选，用于手机访问） =====
# ngrok 程序路径，留空默认使用系统 PATH 中的 ngrok
# Windows 示例: NGROK_PATH=E:\\ngrok\\ngrok.exe
# Mac/Linux 示例: NGROK_PATH=/usr/local/bin/ngrok
NGROK_PATH=ngrok
